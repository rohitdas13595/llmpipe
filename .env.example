# llmpipe — copy to `.env` and fill in values:
#   cp .env.example .env
# voicebot loads `.env` from the current working directory (run from this folder).

# ----- cmd/voicebot (WebSocket) -----
LISTEN=:8080
SAMPLE_RATE=16000

# Optional energy VAD tuning (browser mics are often quiet). Defaults: 120 / 2 / 6.
# VAD_RMS_THRESHOLD=120
# VAD_MIN_SPEECH=2
# VAD_MIN_SILENCE=6

# Turns (Pipecat-style): time-based end of user utterance after last speech (ms). When set, overrides frame-only VAD_MIN_SILENCE for “stopped”.
# TURN_SILENCE_MS=3000
# Emit TurnStartedFrame / TurnEndedFrame downstream of VAD (for observers). Set 0 to disable.
# TURN_TRACK=1

# Deepgram: skip HTTP when audio is too short / too quiet (saves API + bandwidth). Defaults ~100ms + RMS 55.
# STT_MIN_PCM_BYTES=4800
# STT_MIN_RMS=55
# STT_GATE_LOG=1
# Log empty transcripts after API (usually off): STT_EMPTY_LOG=1

# PIPELINE=classic | gemini_live | openai_realtime  (realtime = single bidirectional session; see docs/PROVIDERS.md vs ../pipecat)
PIPELINE=classic

# Providers (classic): STT = deepgram | google | openai | groq | assemblyai | aws | sarvam
#                      LLM = openai | google | gemini | anthropic | groq | azure | together | xai | mistral | …
#                            (full OpenAI-compat list in providers/openai_compat_llm.go + docs/PROVIDERS.md)
#                      TTS = elevenlabs | openai | groq | google | aws | sarvam
STT=deepgram
LLM=openai
TTS=elevenlabs

SYSTEM_PROMPT=You are a concise voice assistant.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=   # optional: OpenAI-compatible endpoints (Together, etc.)
# OPENAI_WHISPER_MODEL=whisper-1
# OPENAI_TTS_VOICE=alloy
# OPENAI_TTS_MODEL=tts-1

DEEPGRAM_API_KEY=
WHISPER_LANGUAGE=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Groq (STT=groq, LLM=groq, TTS=groq) — Pipecat: pipecat/services/groq
GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_STT_MODEL=whisper-large-v3-turbo
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
# GROQ_TTS_VOICE=autumn

# Azure OpenAI (LLM=azure) — deployment-scoped base URL + api-version query (see providers/registry.go)
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_MODEL=gpt-4o   # optional; defaults to deployment name

# Examples: Together / Mistral / OpenRouter / DeepSeek / Ollama — set LLM=together etc. and matching *_API_KEY / *_MODEL (see docs/PROVIDERS.md)
# TOGETHER_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.2

# Anthropic (LLM=anthropic) — Pipecat: pipecat/services/anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_MAX_TOKENS=1024

# AssemblyAI (STT=assemblyai) — Pipecat streaming differs; llmpipe uses REST upload+poll
ASSEMBLYAI_API_KEY=

# Realtime (PIPELINE=gemini_live | openai_realtime)
# GEMINI_LIVE_MODEL=gemini-2.0-flash-live-preview-04-09
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Sarvam TTS (when TTS=sarvam). Header: api-subscription-key
SARVAM_API_KEY=
# Optional: en-IN, hi-IN, etc.; speaker must match bulbul:v3 list in Sarvam docs
SARVAM_LANGUAGE=en-IN
SARVAM_SPEAKER=shubh
SARVAM_TTS_MODEL=bulbul:v3
# SARVAM_PACE=1.0

# Gemini / Google LLM (when LLM=google or LLM=gemini). Prefer GEMINI_API_KEY; GOOGLE_API_KEY also works.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_STT_MODEL=gemini-2.0-flash   # when STT=google (Gemini audio transcribe)
# GOOGLE_API_KEY=

# ----- cmd/voicebot-livekit -----
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_ROOM=demo
LIVEKIT_IDENTITY=llmpipe-agent
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Embedded browser demo (livekit-voicebot-client.html). Default :8090. Set off or - to disable.
LIVEKIT_DEMO_LISTEN=:8090
# Signalling timeout per edge attempt (default 30s if unset). SDK default is 3s and often fails on slow links.
# LIVEKIT_CONNECT_TIMEOUT=45s
# LiveKit Cloud: set 1 to skip regional URL rotation and use LIVEKIT_URL only (helps some firewalls).
# LIVEKIT_DISABLE_REGION_DISCOVERY=1
# Force TURN only when UDP/WebRTC is blocked: relay
# LIVEKIT_ICE_TRANSPORT=relay
