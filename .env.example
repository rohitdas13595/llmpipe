# llmpipe — copy to `.env` and fill in values:
#   cp .env.example .env
# voicebot loads `.env` from the current working directory (run from this folder).

# ----- cmd/voicebot (WebSocket) -----
LISTEN=:8080
SAMPLE_RATE=16000

# Optional energy VAD tuning (browser mics are often quiet). Defaults: 120 / 2 / 6.
# VAD_RMS_THRESHOLD=120
# VAD_MIN_SPEECH=2
# VAD_MIN_SILENCE=6

# Deepgram: skip HTTP when audio is too short / too quiet (saves API + bandwidth). Defaults ~100ms + RMS 55.
# STT_MIN_PCM_BYTES=4800
# STT_MIN_RMS=55
# STT_GATE_LOG=1
# Log empty transcripts after API (usually off): STT_EMPTY_LOG=1

# Providers: STT = deepgram | google | aws | sarvam
#            LLM = openai | google | gemini   (gemini = same as google, Gemini API)
#            TTS = elevenlabs | google | aws | sarvam
STT=deepgram
LLM=openai
TTS=elevenlabs

SYSTEM_PROMPT=You are a concise voice assistant.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DEEPGRAM_API_KEY=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Sarvam TTS (when TTS=sarvam). Header: api-subscription-key
SARVAM_API_KEY=
# Optional: en-IN, hi-IN, etc.; speaker must match bulbul:v3 list in Sarvam docs
SARVAM_LANGUAGE=en-IN
SARVAM_SPEAKER=shubh
SARVAM_TTS_MODEL=bulbul:v3
# SARVAM_PACE=1.0

# Gemini / Google LLM (when LLM=google or LLM=gemini). Prefer GEMINI_API_KEY; GOOGLE_API_KEY also works.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=

# ----- cmd/voicebot-livekit -----
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_ROOM=demo
LIVEKIT_IDENTITY=llmpipe-agent
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
